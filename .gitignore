# SLURM / run-time artifacts
logs/
# Un-ignore results/saebench/logs/ specifically — the bare `logs/`
# rule above matches any directory named `logs`, which otherwise
# swallows the SAEBench training logs we want to commit.
!results/saebench/logs/
!results/saebench/logs/**
han_plots/
report/
temporal_crosscoders/logs/
